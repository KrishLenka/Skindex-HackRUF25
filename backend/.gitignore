# Backend-specific ignores

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Prepared SCIN splits (large; generated by prepare_scin_data.py)
data_scin/

# Model outputs (keep directory, ignore files)
models/*.pth
models/*.pt
models/*.h5
models/*.onnx
models/*.pb
!models/.gitkeep
!models/README.md

# Training outputs
checkpoints/*.pth
checkpoints/*.pt
!checkpoints/.gitkeep

logs/*.png
logs/*.txt
logs/*.json
!logs/.gitkeep

evaluation/*.png
evaluation/*.txt
evaluation/*.json
!evaluation/.gitkeep

# Database
db/*
!db/.gitkeep

# Temporary files
*.tmp
*.log
